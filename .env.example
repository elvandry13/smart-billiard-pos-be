# Django Settings
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_SETTINGS_MODULE=core.settings
DJANGO_ENV=development
DJANGO_DEBUG=True

# Super Admin Seed Credentials (untuk management command seed_superadmin)
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=CHANGE_ME__STRONG_PASSWORD_PLEASE
SUPER_ADMIN_PHONE=

# Phase 1 Frontend E2E Seed (untuk management command seed_phase1)
# Jangan isi credential test nyata di repository. Salin ke .env lokal/password manager.
PHASE1_TENANT_NAME=Phase 1 Tenant
PHASE1_TENANT_CODE=PHASE1
PHASE1_OUTLET_NAME=Phase 1 Outlet
PHASE1_OUTLET_CODE=P1O1
PHASE1_OUTLET_ADDRESS=
PHASE1_OUTLET_TIMEZONE=Asia/Jakarta
PHASE1_SUPER_ADMIN_USERNAME=phase1_super_admin
PHASE1_SUPER_ADMIN_EMAIL=phase1_super_admin@example.com
PHASE1_SUPER_ADMIN_PASSWORD=CHANGE_ME__LOCAL_ONLY
PHASE1_OWNER_USERNAME=phase1_owner
PHASE1_OWNER_EMAIL=phase1_owner@example.com
PHASE1_OWNER_PASSWORD=CHANGE_ME__LOCAL_ONLY
PHASE1_ADMIN_USERNAME=phase1_admin
PHASE1_ADMIN_EMAIL=phase1_admin@example.com
PHASE1_ADMIN_PASSWORD=CHANGE_ME__LOCAL_ONLY
PHASE1_OFFICER_USERNAME=phase1_officer
PHASE1_OFFICER_EMAIL=phase1_officer@example.com
PHASE1_OFFICER_PASSWORD=CHANGE_ME__LOCAL_ONLY

# Database (SQLite untuk development)
DATABASE_URL=sqlite:///db.sqlite3

# Database (PostgreSQL untuk production)
DB_NAME=postgres
DB_USER=POSTGRES_USER
DB_PASSWORD=CHANGE_ME__STRONG_PASSWORD_PLEASE
DB_HOST=POSTGRES_HOST
DB_PORT=5432

# Allowed Hosts (comma-separated)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1