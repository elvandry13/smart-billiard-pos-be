# Django Settings
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_SETTINGS_MODULE=core.settings
DJANGO_ENV=development
DJANGO_DEBUG=True

# Super Admin Seed Credentials (untuk management command seed_superadmin)
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=CHANGE_ME__STRONG_PASSWORD_PLEASE
SUPER_ADMIN_PHONE=

# Database (PostgreSQL untuk production)
DATABASE_URL=sqlite:///db.sqlite3

# Allowed Hosts (comma-separated)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL for production/docker)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=smart_billiard_pos
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Sentry Error Monitoring
# SENTRY_DSN=https://xxxxx@yyyyy.ingest.sentry.io/project-id (leave empty to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

# Gunicorn (production)
GUNICORN_WORKERS=4

# HSTS (production)
SECURE_HSTS_SECONDS=31536000
