# Django Settings
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_SETTINGS_MODULE=core.settings
DJANGO_ENV=development
DJANGO_DEBUG=True

# Super Admin Seed Credentials (untuk management command seed_superadmin)
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=CHANGE_ME__STRONG_PASSWORD_PLEASE
SUPER_ADMIN_PHONE=

# Database (SQLite untuk development)
DATABASE_URL=sqlite:///db.sqlite3

# Database (PostgreSQL untuk production)
DB_NAME=postgres
DB_USER=POSTGRES_USER
DB_PASSWORD=CHANGE_ME__STRONG_PASSWORD_PLEASE
DB_HOST=POSTGRES_HOST
DB_PORT=5432

# Allowed Hosts (comma-separated)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1